// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum SpaceType {
  Indoor
  Outdoor
}

enum Amenity {
  Outlets
  AirConditioning
  WiFi
  Printing
  Whiteboards
  ReservableRooms
  Accessible
  WaterRefill
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  role     Role     @default(USER)
}

enum Standing {
  Freshman
  Sophmore
  Junior
  Senior
  Graduate
  Other
}

model ProfileImage {
  imageID          Int      @id @default(autoincrement())
  profileID        Int      
  fileName         String
  profile          Profile  @relation(fields: [profileID], references: [profileID])
}

model Profile {
  id        Int  
  profileID Int  @id @default(autoincrement())
  fullName  String
  major     String
  classes   String
  Interests String
  picture   ProfileImage[] 
  status    String
  standing  Standing @default(Freshman)
}

enum Occupancy {
  Empty
  Moderate
  Crowded
}

enum NoiseLevel {
  Quiet
  Moderate
  Loud
}

enum FoodAllowed {
  Permitted
  Prohibited
  Water
}

model Listing {
  listingID        Int          @id @default(autoincrement())
  buildingName     String 
  roomNumber       String
  times            Times[]
  pictures         Image[]
  occupancy        Occupancy    @default(Moderate)
  foodAllowed      FoodAllowed  @default(Prohibited)
  noiseLevel       NoiseLevel   @default(Moderate)
  spaceType        SpaceType    @default(Indoor)
  capacity         Int          @default(1)
  createdAt        DateTime @default(now())
  amenities        ListingAmenity[]
}

model AmenityEntity {
  id        Int      @id @default(autoincrement())
  name      Amenity  @unique
  listings  ListingAmenity[]
}

model ListingAmenity {
  listingID Int
  amenityID Int

  listing   Listing        @relation(fields: [listingID], references: [listingID], onDelete: Cascade)
  amenity   AmenityEntity  @relation(fields: [amenityID], references: [id], onDelete: Cascade)

  @@id([listingID, amenityID])
}

model Image {
  imageID          Int      @id @default(autoincrement())
  listingID        Int
  fileName         String
  listing          Listing  @relation(fields: [listingID], references: [listingID], onDelete: Cascade)
}

model Times {
  timeID           Int      @id @default(autoincrement())
  listingID        Int
  startTime        String   
  endTime          String   
  listing          Listing  @relation(fields: [listingID], references: [listingID], onDelete: Cascade)
}

enum Condition {
  excellent
  good
  fair
  poor
}

model Stuff {
  id        Int       @id @default(autoincrement())
  name      String
  quantity  Int
  condition Condition @default(good)
  owner     String
}
