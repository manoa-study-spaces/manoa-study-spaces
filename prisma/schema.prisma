// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // for local development
  // url      = env("DATABASE_URL")
  // for Vercel
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

enum Role {
  USER
  ADMIN
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  role     Role     @default(USER)
}

enum Occupancy {
  Empty
  Moderate
  Crowded
}

enum NoiseLevel {
  Quiet
  Moderate
  Loud
}

enum FoodAllowed {
  Permitted
  Prohibited
  Water
}

model Listing {
  listingID        Int          @id @default(autoincrement())
  buildingName     String 
  roomNumber       String
  times            Times[]
  pictures         Image[]
  occupancy        Occupancy    @default(Moderate)
  foodAllowed      FoodAllowed  @default(Prohibited)
  noiseLevel       NoiseLevel   @default(Moderate)
}

model Image {
  imageID          Int      @id @default(autoincrement())
  listingID        Int
  fileName         String
  listing          Listing  @relation(fields: [listingID], references: [listingID], onDelete: Cascade)
}

model Times {
  timeID           Int      @id @default(autoincrement())
  listingID        Int
  startTime        DateTime @db.Time
  endTime          DateTime @db.Time
  listing          Listing  @relation(fields: [listingID], references: [listingID], onDelete: Cascade)
}

enum Condition {
  excellent
  good
  fair
  poor
}

model Stuff {
  id        Int       @id @default(autoincrement())
  name      String
  quantity  Int
  condition Condition @default(good)
  owner     String
}
